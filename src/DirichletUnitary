local notation "ζ" => riemannZeta

noncomputable section

/-!
## Core Definitions
-/

/-- The kernel function: n^((1-2σ)*r)
    This is the r-th term of the unitarity sum. -/
def kernel_f (n : ℕ) (r : Fin n) (σ : ℝ) : ℝ :=
  (n : ℝ)^(((1 : ℝ) - 2 * σ) * (r : ℝ))

/-- First derivative of kernel_f with respect to σ -/
def kernel_f' (n : ℕ) (r : Fin n) (σ : ℝ) : ℝ :=
  -((2 : ℝ) * Real.log (n : ℝ) * (r : ℝ)) *
  (n : ℝ)^(((1 : ℝ) - 2 * σ) * (r : ℝ))

/-- The Dirichlet vector for base n at complex
    frequency s: the r-th component is n^(-sr) -/
def dirichlet_vector (n : ℕ) (s : ℂ) : Fin n → ℂ :=
  fun r => (n : ℂ)^(-(s * (r : ℝ)))

/-- The partial Dirichlet sum: the polygon vertex
    after N steps -/
def partial_sum (N : ℕ) (s : ℂ) : ℂ :=
  ∑ n ∈ Finset.Icc 1 N, (n : ℂ)^(-s)

/-!
## Polygonal chains in ℂ

A polygonal chain is encoded as:
- a sequence of directions `θ : ℕ → ℝ` (angles)
- a sequence of positive lengths `r : ℕ → ℝ`

The chain "closes at the origin" means the infinite sum of
steps `r n * exp(i * θ n)` converges to zero.

The lemma asserts: if two chains share the same direction sequence
but have different positive length profiles, they cannot both close.
-/

/-- A step vector: length `r` in direction `θ` -/
noncomputable def step (r : ℝ) (θ : ℝ) : ℂ :=
  r * Complex.exp (Complex.I * θ)

def ClosesAtOrigin (r : ℕ → ℝ) (θ : ℕ → ℝ) : Prop :=
  Summable (fun n => step (r n) (θ n)) ∧
  ∑' n, step (r n) (θ n) = 0

/-- Two chains with the same directions and the same step norms
    must have equal step lengths at each index. -/
lemma closing_chains_same_directions_equal_norms
    (r s : ℕ → ℝ)
    (θ : ℕ → ℝ)
    (hr : ∀ n, 0 < r n)
    (hs : ∀ n, 0 < s n)
    (hn : ∀ n, ‖step (r n) (θ n)‖ = ‖step (s n) (θ n)‖) :
    ∀ n, r n = s n := by
  intro n
  have h := hn n
  -- Expand the norm of a step
  simp [step,
        Real.norm_of_nonneg (le_of_lt (hr n)),
        Real.norm_of_nonneg (le_of_lt (hs n))] at h
  exact h

/-!
## Lemma 1: Polygon Representation
-/

/-- AXIOM: The Dirichlet series converges to ζ(s)
    for 0 < Re(s) < 1 via analytic continuation. -/
axiom analytic_continuation_dirichlet_sum :
    ∀ {s : ℂ}, 0 < s.re → s.re < 1 →
      Filter.Tendsto (fun N => partial_sum N s)
        Filter.atTop (nhds (ζ s))

lemma polygon_closure_means_zero (s : ℂ)
    (hs : 0 < s.re ∧ s.re < 1)
    (hz : ζ s = 0) :
    Filter.Tendsto (fun N => partial_sum N s)
      Filter.atTop (nhds 0) := by
  have h := analytic_continuation_dirichlet_sum
    hs.1 hs.2
  simpa [hz] using h

/-!
## Lemma 2: Divergent Turning Angle
-/
/-- The total turning angle diverges in absolute value -/
lemma turning_angle_diverges (t : ℝ) (ht : t ≠ 0) :
    Filter.Tendsto
      (fun N => |∑ n ∈ Finset.range N,
        (t * Real.log (↑n + 2) - t * Real.log (↑n + 1))|)
      Filter.atTop Filter.atTop := by
  have htelescope : ∀ N : ℕ,
      ∑ n ∈ Finset.range N,
        (t * Real.log (↑n + 2) - t * Real.log (↑n + 1)) =
      t * Real.log (↑N + 1) := by
    intro N
    induction N with
    | zero => simp
    | succ n ih =>
      rw [Finset.sum_range_succ, ih]
      push_cast
      rw [show Real.log (↑n + 1 + 1) =
          Real.log (↑n + 2) from by norm_cast]
      ring
  simp_rw [htelescope, abs_mul]
  -- |t| * |log(N+1)| → ∞
  -- Use const_mul_atTop: r * f → ∞ when r > 0 and f → ∞
  apply Filter.Tendsto.const_mul_atTop (abs_pos.mpr ht)
  -- |log(N+1)| = log(N+1) ≥ 0, and log(N+1) → ∞
  have hnn : ∀ N : ℕ, 0 ≤ Real.log (↑N + 1) := by
    intro N
    apply Real.log_nonneg
    have : (0 : ℝ) ≤ N := Nat.cast_nonneg N
    linarith
  simp_rw [abs_of_nonneg (hnn _)]
  -- log(N+1) → ∞
  apply Real.tendsto_log_atTop.comp
  apply Filter.Tendsto.atTop_add
  · exact tendsto_natCast_atTop_atTop
  · exact tendsto_const_nhds

/-!
## Lemma 3: Algebraic norm identity
-/

/-- The squared norm of the Dirichlet vector depends
    only on σ = Re(s), not on t = Im(s). -/
lemma norm_sq_dirichlet_vector (n : ℕ) (hn : 0 < n) (s : ℂ) (r : Fin n) :
    Complex.normSq (dirichlet_vector n s r) = (n : ℝ) ^ (-2 * s.re * (r : ℝ)) := by
  unfold dirichlet_vector
  -- 1. normSq z = ‖z‖^2
  rw [Complex.normSq_eq_norm_sq]
  -- 2. Use the approved identity: ‖n^(-s*r)‖ = n^(re(-s*r))
  have h_norm : ‖(n : ℂ) ^ (-(s * (r : ℝ)))‖ = (n : ℝ) ^ (-(s.re * (r : ℝ))) := by
    -- re(-(s * r)) = -s.re * r
    have h_re : (-(s * (r : ℝ))).re = -(s.re * (r : ℝ)) := by
      simp only [Complex.neg_re, Complex.mul_re, Complex.ofReal_re,
                 Complex.ofReal_im, mul_zero, sub_zero]
    rw [Complex.norm_natCast_cpow_of_pos hn, h_re]
  rw [h_norm]
  -- 3. Square the result: (n^(-σr))^2 = n^(-2σr)
  rw [← Real.rpow_two, ← Real.rpow_mul]
  · ring_nf
  · exact_mod_cast Nat.zero_le n

/-- The weighted norm sum equals the kernel sum.
    This is the bridge from complex geometry to the
    real unitarity condition. -/
lemma complex_to_real_kernel_link (n : ℕ) (hn : 0 < n)
    (s : ℂ) :
    (∑ r : Fin n, (n : ℝ)^(r : ℝ) *
      Complex.normSq (dirichlet_vector n s r)) =
    ∑ r : Fin n, kernel_f n r s.re := by
  apply Finset.sum_congr rfl
  intro r _
  rw [norm_sq_dirichlet_vector n hn s r]
  unfold kernel_f
  have hn_real : 0 < (n : ℝ) := by norm_cast
  rw [← Real.rpow_add hn_real]
  congr 1; ring

/-!
## Lemma 4: The unitarity sum is strictly monotone
-/

/-- Derivative of (1-2x)*r is -2r -/
lemma hasDerivAt_exponent (σ : ℝ) (r : ℝ) :
    HasDerivAt (fun x => ((1 : ℝ) - 2 * x) * r)
      (-2 * r) σ := by
  have h := ((hasDerivAt_id σ).const_mul 2).const_sub 1
  simp only [id, mul_one] at h
  convert h.mul_const r using 1

/-- The kernel function has the correct derivative -/
lemma hasDerivAt_kernel (n : ℕ) (hn : 1 < n)
    (r : Fin n) (σ : ℝ) :
    HasDerivAt (kernel_f n r) (kernel_f' n r σ) σ := by
  have hn0 : 0 < (n : ℝ) := by norm_cast; linarith
  unfold kernel_f kernel_f'
  convert HasDerivAt.const_rpow hn0
    (hasDerivAt_exponent σ (r : ℝ)) using 1
  ring

/-- The unitarity sum F_n(σ) is strictly decreasing
    on [0,1] -/
lemma sum_rpow_strictly_decreasing (n : ℕ) (hn : 1 < n) :
    StrictAntiOn
      (fun σ => ∑ r : Fin n, kernel_f n r σ)
      (Icc 0 1) := by
  have hn_pos : (0 : ℝ) < n := by norm_cast; linarith
  apply strictAntiOn_of_deriv_neg (convex_Icc 0 1)
  · apply Continuous.continuousOn
    apply continuous_finset_sum
    intro r _
    unfold kernel_f
    apply Continuous.rpow continuous_const
      (by continuity)
    intro x; left; linarith
  · intro σ hσ
    have h_deriv : HasDerivAt
        (fun x => ∑ r : Fin n, kernel_f n r x)
        (∑ r : Fin n, kernel_f' n r σ) σ :=
      HasDerivAt.fun_sum (fun r _ =>
        hasDerivAt_kernel n hn r σ)
    rw [h_deriv.deriv]
    have hn_log : 0 < Real.log n :=
      Real.log_pos (by norm_cast)
    have h_nonpos : ∀ r : Fin n,
        kernel_f' n r σ ≤ 0 := by
      intro r; unfold kernel_f'
      have h_pow : 0 < (n : ℝ)^((1 - 2 * σ) * (r : ℝ)) :=
        rpow_pos_of_pos hn_pos _
      have h_prod : 0 ≤ 2 * Real.log n * (r : ℝ) :=
        mul_nonneg
          (mul_nonneg (by linarith) (le_of_lt hn_log))
          (by exact_mod_cast r.val.zero_le)
      nlinarith [mul_nonneg h_prod (le_of_lt h_pow)]
    have h1_neg : kernel_f' n ⟨1, hn⟩ σ < 0 := by
      unfold kernel_f'
      simp only [Nat.cast_one]
      have h_pow : 0 < (n : ℝ)^((1 - 2 * σ) * 1) :=
        rpow_pos_of_pos hn_pos _
      have h_log_pos : 0 < Real.log n := hn_log
      nlinarith [mul_pos (mul_pos
        (by linarith) h_log_pos) h_pow]
    have hsplit : ∑ r : Fin n, kernel_f' n r σ =
        kernel_f' n ⟨1, hn⟩ σ +
        ∑ r ∈ Finset.univ.erase ⟨1, hn⟩,
          kernel_f' n r σ :=
      (Finset.add_sum_erase _ _
        (Finset.mem_univ _)).symm
    have h_rest : ∑ r ∈ Finset.univ.erase ⟨1, hn⟩,
        kernel_f' n r σ ≤ 0 :=
      Finset.sum_nonpos (fun r _ => h_nonpos r)
    linarith [hsplit]

/-!
## Lemma 5: Unitarity condition (CORE VERIFIED LEMMA)
-/

/-- CORE LEMMA: The unitarity sum equals n if and
    only if σ = 1/2.
    This is the discrete isometry condition. -/
lemma unitarity_sum_condition
    (σ : ℝ) (hσ : σ ∈ Icc 0 1)
    (n : ℕ) (hn : 1 < n) :
    (∑ r : Fin n, kernel_f n r σ) = (n : ℝ) ↔
    σ = 1/2 := by
  have hf_mono : StrictAntiOn
      (fun x => ∑ r : Fin n, kernel_f n r x)
      (Icc 0 1) :=
    sum_rpow_strictly_decreasing n hn
  have h12_mem : (1/2 : ℝ) ∈ Icc 0 1 := by norm_num
  have h_f12 : ∑ r : Fin n, kernel_f n r (1/2) =
      (n : ℝ) := by
    have h_one : ∀ r : Fin n,
        kernel_f n r (1/2) = 1 := by
      intro r; unfold kernel_f; norm_num
    simp_rw [h_one, Finset.sum_const,
             Finset.card_fin, nsmul_eq_mul, mul_one]
  constructor
  · intro h
    apply hf_mono.injOn hσ h12_mem
    simp only [h, h_f12]
  · rintro rfl; exact h_f12

/-!
## Proposition: Critical Length Profile
-/

/-- If the weighted norm of the Dirichlet vector
    equals n, then σ = 1/2.
    This is the formal content of "the polygon
    can only close at the critical length profile." -/
lemma critical_length_profile (n : ℕ) (hn : 1 < n)
    (s : ℂ) (hs : s.re ∈ Icc 0 1) :
    (∑ r : Fin n, (n : ℝ)^(r : ℝ) *
      Complex.normSq (dirichlet_vector n s r)) =
    (n : ℝ) → s.re = 1/2 := by
  intro h
  rw [complex_to_real_kernel_link n (by linarith
    [hs.1, show (0:ℝ) < 1 from one_pos]) s] at h
  exact (unitarity_sum_condition s.re hs n hn).mp h

/-!
## The Axiom: Unitarity Selection Principle
-/

/-- AXIOM (Unitarity Selection Principle):
    A zero of ζ(s) in the critical strip forces
    the unitarity condition for every integer n > 1.

    This axiom expresses the global selection
    principle: among all decay profiles n^(-σ),
    the only profile compatible with a zero is
    the unitary profile σ = 1/2.

    Mathematical content of this axiom:
    The infinite polygon ∑ n^(-s) = 0 implies
    that the side lengths n^(-σ) satisfy the
    isometry condition, excluding pointwise
    phase cancellations outside σ = 1/2.

    This is the caveat identified in the manuscript:
    proving this axiom unconditionally would require
    showing that ζ(s) = 0 forces the norm condition
    independently of the hypothesis σ = 1/2. -/
axiom ax_unitarity (s : ℂ)
    (hs : 0 < s.re ∧ s.re < 1)
    (hz : ζ s = 0) (n : ℕ) (hn : 1 < n) :
    ∑ r : Fin n, kernel_f n r s.re = n

/-!
## Main Theorem: Conditional RH via Dirichlet Series
-/

/-- CONDITIONAL RH (Dirichlet Series):
    Assuming the Unitarity Selection Principle,
    all non-trivial zeros of ζ(s) lie on σ = 1/2.

    The proof uses only n = 2: the unitarity sum
    ∑_{r=0}^{1} 2^{(1-2σ)r} = 2 forces σ = 1/2
    by unitarity_sum_condition. -/
theorem riemann_hypothesis_dirichlet (s : ℂ)
    (hs_strip : 0 < s.re ∧ s.re < 1)
    (hz : ζ s = 0) : s.re = 1/2 := by
  -- Apply the axiom with n = 2
  have h_unit : ∑ r : Fin 2, kernel_f 2 r s.re = 2 :=
    ax_unitarity s hs_strip hz 2 (by norm_num)
  -- Apply the unitarity condition
  have hσ_mem : s.re ∈ Icc 0 1 :=
    ⟨le_of_lt hs_strip.1, le_of_lt hs_strip.2⟩
  exact (unitarity_sum_condition s.re hσ_mem 2
    (by norm_num)).mp h_unit

